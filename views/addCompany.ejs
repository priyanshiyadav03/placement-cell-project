<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Add New Company</title>
</head>
<body>

<h2 class="text-center mb-4">Add New Job Opening</h2>
<%- include('partials/layout') %>

<div class="container mt-4">
  <h2>Company Directory</h2>
</div>


<form method="POST" action="/add-company" class="w-50 mx-auto bg-white p-4 rounded shadow-sm">
    <div class="mb-3">

  <label class="form-label">Company Name:</label><br>
  <input type="text" class="form-control" name="name" required><br><br>
</div>
<div class="mb-3">
  <label class="form-label">Job Role:</label><br>
  <input type="text" class="form-control" name="job_role" required><br><br>
</div>
<div class="mb-3">
  <label class="form-label">Eligibility CGPA:</label><br>
  <input type="number" step="0.1" class="form-control" name="eligibility_cgpa" required><br><br>
</div>
<div class="mb-3">
  <label class="form-label">Package (LPA):</label><br>
  <input type="number" step="0.1" class="form-control" name="package" required><br><br>
</div>
<div class="mb-3">
  <label class="form-label">Description:</label><br>
  <textarea name="description" class="form-control" rows="3" cols="40" required></textarea><br><br>
</div>
<div class="text-center">
  <button type="submit" class="btn btn-primary">Add Opening</button>
  </div>
</form>

<br>
<a href="/dashboard">← Back to Dashboard</a>
</body>
</html>